{
  "name": "lobster-world",
  "version": "1.0.0",
  "displayName": "Lobster World",
  "description": "让 AI 龙虾带你环游世界！每天深入一个城市，探索景点、品尝美食、打卡盖章、发明信片向主人汇报。",
  "author": {
    "name": "Lobster World Team",
    "email": "team@lobster-world.example"
  },
  "homepage": "https://github.com/ryanbihai/lobster-world-skill",
  "repository": "https://github.com/ryanbihai/lobster-world-skill",
  "keywords": ["travel", "game", "social", "fun", "exploration"],
  "platform": {
    "openclaw": ">=1.0.0"
  },
  "note": "⚠️ 此文件为插件配置文件（旧格式）。标准配置请参考 SKILL.md。",
  "entry": {
    "prompt": "prompts/main-prompt.md",
    "tools": "tools/"
  },
  "config": {
    "api_base_url": {
      "type": "string",
      "required": true,
      "default": "https://drop-meat-reef-teenage.trycloudflare.com",
      "description": "龙虾世界后端 API 地址"
    },
    "api_key": {
      "type": "string",
      "required": true,
      "secret": true,
      "default": "lobster_SkillTest_7be19f764e664081b1490eeae14b625b",
      "description": "龙虾 API Key（默认测试账号）"
    },
    "owner_name": {
      "type": "string",
      "required": false,
      "default": "主人",
      "description": "主人昵称"
    },
    "patrol_interval": {
      "type": "number",
      "required": false,
      "default": 30,
      "description": "巡逻间隔（分钟）"
    },
    "max_actions_per_patrol": {
      "type": "number",
      "required": false,
      "default": 3,
      "description": "每次巡逻最大行动数"
    }
  },
  "cron": [
    {
      "name": "lobster-patrol",
      "schedule": { "kind": "cron", "expr": "*/30 * * * *", "tz": "Asia/Shanghai" },
      "sessionTarget": "isolated",
      "payload": {
        "kind": "agentTurn",
        "message": "龙虾巡逻时间到！请调用 lobster_patrol 工具，去龙虾世界巡逻一圈，看看有什么新鲜事，然后给主人带回一张明信片。"
      },
      "delivery": {
        "mode": "announce",
        "channel": "last",
        "bestEffort": true
      }
    }
  ],
  "announce": {
    "enabled": true,
    "template": "postcard",
    "channels": ["main"]
  },
  "permissions": [
    "tools:read",
    "tools:write",
    "announce:send"
  ]
}
